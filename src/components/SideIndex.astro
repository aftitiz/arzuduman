---
// Masaüstü yan index (monograf). Aktif bölüm scroll ile vurgulanır (Reveal script).
const items = [
  { id: 'hakkimda',   label: 'Hakkımda' },
  { id: 'uzmanlik',   label: 'Uzmanlık' },
  { id: 'surec',      label: 'Süreç' },
  { id: 'deneyimler', label: 'Deneyimler' },
  { id: 'randevu',    label: 'Ön Görüşme' },
  { id: 'sss',        label: 'SSS' },
];
---

<nav class="side-index" data-side-index aria-label="Sayfa içi gezinme">
  {items.map((it, i) => (
    <a href={`#${it.id}`} data-target={it.id}>
      <span class="si-num">{String(i + 1).padStart(2, '0')}</span>
      <span class="si-dot" aria-hidden="true"></span>
      <span class="si-label">{it.label}</span>
    </a>
  ))}
</nav>
