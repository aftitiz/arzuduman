---
import Eyebrow from './Eyebrow.astro';
const { manifesto } = Astro.props;
---

<section style="position:relative; overflow:hidden; background:var(--ink-2); padding:clamp(100px,15vw,200px) var(--pad-x);">
  <!-- Havuzlanan sıcak ışık -->
  <div aria-hidden="true" style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:min(120vw,1100px); height:min(80vw,700px); border-radius:50%; background:radial-gradient(circle at 50% 50%, rgba(201,161,107,0.10), rgba(201,161,107,0) 62%); pointer-events:none;"></div>

  <div style="position:relative; z-index:2; max-width:1040px; margin:0 auto; text-align:center;">
    <div data-reveal>
      <Eyebrow label={manifesto.eyebrow} center={true} mb="34px" lineWidth="26px" />
    </div>
    <p
      data-reveal
      data-reveal-delay="90"
      style="margin:0; font-family:var(--serif); font-weight:500; font-size:clamp(30px,4.8vw,66px); line-height:1.16; letter-spacing:-0.012em; color:var(--bone); text-wrap:balance;"
    >
      {manifesto.quoteBefore}<span class="shimmer-accent" style="font-style:italic;">{manifesto.quoteAccent}</span>{manifesto.quoteAfter}
    </p>
  </div>
</section>
