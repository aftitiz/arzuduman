---
// Bölüm üstü küçük etiket: "— çizgi — ETİKET" (mono, şampanya altını).
const {
  label,
  color = 'var(--gold)',
  line = 'var(--gold)',
  center = false,
  mb = '22px',
  lineWidth = '30px',
  spacing = '0.26em',
} = Astro.props;
---

<div
  style={`display:${center ? 'inline-flex' : 'flex'}; align-items:center; gap:12px; margin-bottom:${mb}; font-family:var(--mono); font-size:11.5px; font-weight:500; letter-spacing:${spacing}; text-transform:uppercase; color:${color};`}
>
  <span style={`width:${lineWidth}; height:1px; background:${line}; opacity:.8;`}></span>{label}
</div>
