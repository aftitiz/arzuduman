---
const { nav } = Astro.props;
---

<div class="mobile-cta" style="position:fixed; left:0; right:0; bottom:0; z-index:85; padding:12px 16px calc(12px + env(safe-area-inset-bottom)); background:rgba(14,26,22,0.82); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border-top:1px solid rgba(241,235,222,0.12);">
  <a href={nav.ctaHref} style="display:flex; align-items:center; justify-content:center; gap:9px; width:100%; padding:16px; border-radius:14px; background:#D69A6A; color:#14231C; font-size:16px; font-weight:700; box-shadow:0 10px 26px rgba(214,154,106,0.34);">
    {nav.mobileCta}<span style="font-size:18px;">→</span>
  </a>
</div>
<div class="mobile-cta-spacer" style="height:78px; background:#0B1512;"></div>
