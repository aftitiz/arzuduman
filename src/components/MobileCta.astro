---
const { nav } = Astro.props;
---

<div class="mobile-cta" style="position:fixed; left:0; right:0; bottom:0; z-index:85; padding:12px 16px calc(12px + env(safe-area-inset-bottom)); background:rgba(11,20,16,0.85); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); border-top:1px solid var(--line);">
  <a href={nav.ctaHref} class="btn-accent" style="display:flex; align-items:center; justify-content:center; gap:9px; width:100%; padding:16px; border-radius:14px; font-size:16px; font-weight:700; box-shadow:0 10px 26px rgba(201,161,107,0.32);">
    {nav.mobileCta}<span style="font-size:18px;">→</span>
  </a>
</div>
<div class="mobile-cta-spacer" style="height:78px; background:var(--ink);"></div>
