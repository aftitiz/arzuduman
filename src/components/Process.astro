---
import Eyebrow from './Eyebrow.astro';
const { process } = Astro.props;
---

<section
  id="surec"
  style="position:relative; overflow:hidden; background:#0E1A16; color:#F1EBDE; padding:clamp(80px,10vw,140px) clamp(20px,6vw,88px);"
>
  <div aria-hidden="true" style="position:absolute; top:10%; right:-10%; width:min(60vw,620px); height:min(60vw,620px); border-radius:50%; background:radial-gradient(circle at 50% 50%, rgba(122,158,142,0.16), rgba(122,158,142,0) 66%); filter:blur(24px); animation:drift1 24s ease-in-out infinite; pointer-events:none;"></div>

  <div style="position:relative; z-index:2; max-width:940px; margin:0 auto;">
    <div data-reveal style="max-width:660px; margin-bottom:clamp(44px,6vw,68px);">
      <Eyebrow label={process.eyebrow} color="#D69A6A" line="#D69A6A" />
      <h2 style="margin:0 0 16px; font-family:var(--serif); font-weight:500; font-size:clamp(32px,4.6vw,58px); line-height:1.04; letter-spacing:-0.01em; color:#F1EBDE;">{process.heading}</h2>
      <p style="margin:0; font-size:16.5px; line-height:1.7; color:#B9C3BA;">{process.intro}</p>
    </div>

    <div style="display:flex; flex-direction:column;">
      {process.steps.map((st, i) => (
        <div style="display:flex; gap:clamp(20px,4vw,44px); align-items:stretch;">
          <div style="display:flex; flex-direction:column; align-items:center; flex-shrink:0;">
            <div data-reveal style="display:flex; align-items:center; justify-content:center; width:58px; height:58px; border-radius:50%; border:1px solid rgba(241,235,222,0.28); background:rgba(241,235,222,0.04); font-family:var(--serif); font-size:24px; color:#D69A6A;">{st.n}</div>
            {i < process.steps.length - 1 && (
              <div data-grow style="width:1px; flex:1; min-height:40px; background:linear-gradient(rgba(241,235,222,0.35), rgba(241,235,222,0.04));"></div>
            )}
          </div>
          <div data-reveal data-reveal-delay="80" style="flex:1; padding-bottom:clamp(30px,4vw,46px);">
            <div style="display:flex; flex-wrap:wrap; align-items:center; gap:12px; margin-bottom:10px;">
              <h3 style="margin:0; font-family:var(--serif); font-weight:600; font-size:clamp(22px,2.6vw,30px); color:#F1EBDE;">{st.title}</h3>
              <span style="padding:5px 12px; border-radius:999px; background:rgba(214,154,106,0.14); color:#E4B486; font-size:11.5px; font-weight:700; letter-spacing:0.04em;">{st.tag}</span>
            </div>
            <p style="margin:0; max-width:620px; font-size:15.5px; line-height:1.7; color:#B9C3BA;">{st.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
