---
const { breath } = Astro.props;
---

<section
  id="nefes"
  aria-label="Bir nefes molası"
  style="position:relative; overflow:hidden; min-height:clamp(540px,78vh,740px); display:flex; align-items:center; justify-content:center; background:radial-gradient(135% 100% at 50% 42%, var(--night-2) 0%, var(--night) 56%, var(--night-deep) 100%); color:var(--cream-on-dark); padding:clamp(64px,8vw,104px) var(--pad-x);"
>
  <!-- Dikey kenar vignette: üst/alt en koyuya iner → temiz, keskin nocturne kenarı (kremden iz yok) -->
  <div aria-hidden="true" style="position:absolute; inset:0; background:linear-gradient(180deg, var(--night-deep) 0%, transparent 22%, transparent 78%, var(--night-deep) 100%);"></div>
  <!-- Mum-ışığı: sıcak şampanya havuzu (serin gecede sıcak oda) -->
  <div aria-hidden="true" style="position:absolute; inset:0; background:radial-gradient(58% 58% at 50% 42%, rgba(232,196,140,0.30), transparent 62%);"></div>

  <div data-reveal style="position:relative; z-index:2; display:flex; flex-direction:column; align-items:center; text-align:center; gap:clamp(30px,4vw,46px); max-width:720px;">

    <span class="eyebrow" style="color:var(--amber);">{breath.eyebrow}</span>

    <!-- Nefes halkası -->
    <div class="bi-orb" aria-hidden="true">
      <span class="bi-ring bi-ring-3"></span>
      <span class="bi-ring bi-ring-2"></span>
      <span class="bi-ring bi-ring-1"></span>
      <span class="bi-core"></span>
      <span class="bi-words">
        <span class="bi-word bi-in">{breath.inhale}</span>
        <span class="bi-word bi-out">{breath.exhale}</span>
      </span>
    </div>

    <p style="margin:0; font-family:var(--serif); font-weight:500; font-size:clamp(22px,3vw,36px); line-height:1.32; letter-spacing:-0.01em; color:var(--cream-on-dark); text-wrap:balance;">
      {breath.lineBefore}<span style="font-style:italic; color:var(--amber);">{breath.lineAccent}</span>{breath.lineAfter}
    </p>

    <span class="label-soft" style="color:rgba(244,237,224,0.42);">{breath.cue}</span>
  </div>
</section>

<style>
  .bi-orb {
    position: relative; width: clamp(210px, 40vw, 360px); aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
  }
  .bi-core, .bi-ring {
    position: absolute; top: 50%; left: 50%; border-radius: 50%;
    transform: translate(-50%, -50%) scale(0.92);
  }
  .bi-core {
    width: 62%; height: 62%;
    background: radial-gradient(circle at 46% 40%, rgba(247,224,184,0.6), rgba(201,161,107,0.2) 54%, transparent 74%);
    filter: blur(3px);
  }
  .bi-ring { border: 1px solid rgba(224,180,120,0.3); }
  .bi-ring-1 { width: 62%;  height: 62%; }
  .bi-ring-2 { width: 82%;  height: 82%; border-color: rgba(224,180,120,0.2); }
  .bi-ring-3 { width: 100%; height: 100%; border-color: rgba(224,180,120,0.12); }

  .bi-words { position: relative; z-index: 2; display: grid; place-items: center; }
  .bi-word {
    grid-area: 1 / 1; font-family: var(--serif); font-style: italic;
    font-size: clamp(20px, 2.4vw, 30px); color: var(--cream-on-dark);
  }
  .bi-in  { opacity: 1; }
  .bi-out { opacity: 0; }

  @media (prefers-reduced-motion: no-preference) {
    .bi-core   { animation: bi-scale 9s ease-in-out infinite; }
    .bi-ring-1 { animation: bi-scale 9s ease-in-out infinite; }
    .bi-ring-2 { animation: bi-scale 9s ease-in-out infinite .08s; }
    .bi-ring-3 { animation: bi-scale 9s ease-in-out infinite .16s; }
    .bi-in  { animation: bi-in  9s ease-in-out infinite; }
    .bi-out { animation: bi-out 9s ease-in-out infinite; }
  }
  @keyframes bi-scale { 0%,100% { transform: translate(-50%,-50%) scale(0.8); } 50% { transform: translate(-50%,-50%) scale(1.12); } }
  @keyframes bi-in  { 0%{opacity:0} 12%{opacity:1} 44%{opacity:1} 52%{opacity:0} 100%{opacity:0} }
  @keyframes bi-out { 0%,50%{opacity:0} 60%{opacity:1} 90%{opacity:1} 100%{opacity:0} }
</style>
