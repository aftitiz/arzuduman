---
const { breath } = Astro.props;
---

<section
  id="nefes"
  aria-label="Bir nefes molası"
  style="position:relative; overflow:hidden; min-height:clamp(560px,92vh,900px); display:flex; align-items:center; justify-content:center; background:radial-gradient(120% 90% at 50% 30%, var(--dawn) 0%, var(--dawn-2) 62%, #E1D6BE 100%); color:var(--dawn-ink); padding:clamp(72px,10vw,120px) var(--pad-x);"
>
  <div data-reveal style="position:relative; z-index:2; display:flex; flex-direction:column; align-items:center; text-align:center; gap:clamp(30px,4vw,46px); max-width:720px;">

    <span class="eyebrow" style="color:var(--gold-deep);">{breath.eyebrow}</span>

    <!-- Nefes halkası -->
    <div class="bi-orb" aria-hidden="true">
      <span class="bi-ring bi-ring-3"></span>
      <span class="bi-ring bi-ring-2"></span>
      <span class="bi-ring bi-ring-1"></span>
      <span class="bi-core"></span>
      <span class="bi-words">
        <span class="bi-word bi-in">{breath.inhale}</span>
        <span class="bi-word bi-out">{breath.exhale}</span>
      </span>
    </div>

    <p style="margin:0; font-family:var(--serif); font-weight:500; font-size:clamp(22px,3vw,36px); line-height:1.32; letter-spacing:-0.01em; color:var(--dawn-ink); text-wrap:balance;">
      {breath.lineBefore}<span style="font-style:italic; color:var(--gold-deep);">{breath.lineAccent}</span>{breath.lineAfter}
    </p>

    <span class="label-mono" style="color:#8A7C5E;">{breath.cue}</span>
  </div>
</section>

<style>
  .bi-orb {
    position: relative;
    width: clamp(210px, 40vw, 360px);
    height: clamp(210px, 40vw, 360px);
    display: flex; align-items: center; justify-content: center;
  }
  .bi-core, .bi-ring {
    position: absolute; top: 50%; left: 50%;
    border-radius: 50%; transform: translate(-50%, -50%) scale(0.92);
  }
  .bi-core {
    width: 62%; height: 62%;
    background: radial-gradient(circle at 46% 40%, rgba(201,161,107,0.5), rgba(134,164,145,0.16) 55%, rgba(134,164,145,0) 74%);
    filter: blur(3px);
  }
  .bi-ring { border: 1px solid rgba(166,124,70,0.32); }
  .bi-ring-1 { width: 62%;  height: 62%; }
  .bi-ring-2 { width: 82%;  height: 82%; border-color: rgba(166,124,70,0.22); }
  .bi-ring-3 { width: 100%; height: 100%; border-color: rgba(166,124,70,0.13); }

  .bi-words {
    position: relative; z-index: 2;
    display: grid; place-items: center;
  }
  .bi-word {
    grid-area: 1 / 1;
    font-family: var(--serif); font-style: italic;
    font-size: clamp(20px, 2.4vw, 30px); color: var(--dawn-ink);
  }
  .bi-in  { opacity: 1; }
  .bi-out { opacity: 0; }

  @media (prefers-reduced-motion: no-preference) {
    .bi-core   { animation: bi-scale 9s ease-in-out infinite; }
    .bi-ring-1 { animation: bi-scale 9s ease-in-out infinite; }
    .bi-ring-2 { animation: bi-scale 9s ease-in-out infinite .08s; }
    .bi-ring-3 { animation: bi-scale 9s ease-in-out infinite .16s; }
    .bi-in  { animation: bi-in  9s ease-in-out infinite; }
    .bi-out { animation: bi-out 9s ease-in-out infinite; }
  }

  @keyframes bi-scale {
    0%, 100% { transform: translate(-50%, -50%) scale(0.8); }
    50%      { transform: translate(-50%, -50%) scale(1.12); }
  }
  @keyframes bi-in {
    0% { opacity: 0; } 12% { opacity: 1; } 44% { opacity: 1; } 52% { opacity: 0; } 100% { opacity: 0; }
  }
  @keyframes bi-out {
    0%, 50% { opacity: 0; } 60% { opacity: 1; } 90% { opacity: 1; } 100% { opacity: 0; }
  }
</style>
