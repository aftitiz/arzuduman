---
const { nav } = Astro.props;
---

<nav
  aria-label="Ana menü"
  style="position:fixed; top:18px; left:50%; transform:translateX(-50%); z-index:80; display:flex; align-items:center; gap:clamp(14px,2vw,26px); max-width:calc(100vw - 32px); padding:9px 9px 9px 22px; border-radius:999px; background:rgba(14,26,22,0.58); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); border:1px solid rgba(241,235,222,0.14); box-shadow:0 14px 44px rgba(0,0,0,0.30);"
>
  <a
    href="/"
    style="font-family:var(--serif); font-size:21px; font-weight:600; letter-spacing:0.02em; color:#F1EBDE; white-space:nowrap;"
  >
    {nav.logo}
  </a>

  <div class="nav-links" style="align-items:center; gap:22px;">
    {nav.links.map((link) => (
      <a href={link.href} class="nav-link" style="font-size:13.5px; font-weight:500;">{link.label}</a>
    ))}
  </div>

  <a
    href={nav.ctaHref}
    class="btn-accent"
    style="display:inline-flex; align-items:center; gap:8px; padding:11px 20px; border-radius:999px; font-size:13.5px; font-weight:700; white-space:nowrap;"
  >
    {nav.cta}
  </a>
</nav>
