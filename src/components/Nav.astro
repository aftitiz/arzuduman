---
const { nav } = Astro.props;
---

<nav
  aria-label="Ana menü"
  data-nav
  style="position:fixed; top:18px; left:50%; transform:translateX(-50%); z-index:80; display:flex; align-items:center; gap:clamp(14px,2vw,26px); max-width:calc(100vw - 32px); padding:9px 9px 9px 22px; border-radius:999px; background:var(--glass); backdrop-filter:blur(20px) saturate(1.2); -webkit-backdrop-filter:blur(20px) saturate(1.2); border:1px solid var(--line); box-shadow:0 14px 44px rgba(0,0,0,0.34); transition:padding .4s var(--ease), background .4s ease, box-shadow .4s ease;"
>
  <a
    href="/"
    style="display:inline-flex; align-items:center; gap:10px; font-family:var(--serif); font-size:21px; font-weight:600; letter-spacing:0.02em; color:var(--bone); white-space:nowrap;"
  >
    <span aria-hidden="true" style="width:6px; height:6px; border-radius:50%; background:var(--gold); box-shadow:0 0 10px rgba(201,161,107,.7); animation:breatheDot 6s ease-in-out infinite;"></span>
    {nav.logo}
  </a>

  <div class="nav-links" style="align-items:center; gap:22px;">
    {nav.links.map((link) => (
      <a href={link.href} class="nav-link" style="font-size:13.5px; font-weight:500;">{link.label}</a>
    ))}
  </div>

  <a
    href={nav.ctaHref}
    class="btn-accent nav-cta"
    style="align-items:center; gap:8px; padding:11px 20px; border-radius:999px; font-size:13.5px; font-weight:700; white-space:nowrap;"
  >
    {nav.cta}
  </a>

  <button
    type="button"
    class="nav-toggle"
    data-nav-toggle
    aria-label="Menüyü aç"
    aria-expanded="false"
    aria-controls="nav-overlay"
  >
    <span class="nav-toggle-bars" aria-hidden="true"></span>
  </button>
</nav>

<!-- Mobil tam ekran menü -->
<div class="nav-overlay" id="nav-overlay" data-nav-overlay aria-hidden="true">
  <nav class="nav-overlay-menu" aria-label="Mobil menü">
    {nav.links.map((link) => (
      <a href={link.href} class="nav-menu-link">{link.label}</a>
    ))}
    <a href={nav.ctaHref} class="btn-accent nav-menu-cta">{nav.cta}<span aria-hidden="true">→</span></a>
  </nav>
</div>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const overlay = document.querySelector('[data-nav-overlay]');
  if (toggle && overlay) {
    const setOpen = (open) => {
      overlay.classList.toggle('open', open);
      overlay.setAttribute('aria-hidden', String(!open));
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Menüyü kapat' : 'Menüyü aç');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => setOpen(!overlay.classList.contains('open')));
    overlay.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    // Overlay boşluğuna dokununca kapat
    overlay.addEventListener('click', (e) => { if (e.target === overlay) setOpen(false); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) setOpen(false);
    });
  }
</script>
