---
import Eyebrow from './Eyebrow.astro';
const { about } = Astro.props;
---

<section id="hakkimda" class="section-full" style="position:relative; overflow:hidden; background:linear-gradient(180deg,var(--tone-2),var(--tone-3)); padding:clamp(52px,6vw,88px) var(--pad-x);">
  <div aria-hidden="true" class="aur" style="top:-10%; right:-8%; width:min(46vw,520px); height:min(46vw,520px); background:radial-gradient(circle,rgba(126,154,134,0.22),transparent 66%); animation:drift1 26s ease-in-out infinite;"></div>

  <div class="about-grid" style="position:relative; z-index:2; width:100%; max-width:1200px; margin:0 auto; display:grid; grid-template-columns:minmax(0,0.9fr) minmax(0,1.1fr); gap:clamp(40px,6vw,90px); align-items:center;">

    <div data-reveal class="about-portrait" style="position:relative; display:flex; justify-content:center;">
      <div class="about-glow" aria-hidden="true"></div>
      <div style="position:relative; z-index:1; width:100%; max-width:400px; aspect-ratio:4/5; border-radius:200px 200px 28px 28px; overflow:hidden; background:linear-gradient(160deg,#EADCC6,#D6C4A6); box-shadow:0 44px 96px rgba(38,48,42,0.24), inset 0 0 0 1px rgba(255,255,255,0.4);">
        <div aria-hidden="true" style="position:absolute; top:20%; left:50%; transform:translateX(-50%); width:60%; aspect-ratio:1; border-radius:50%; background:radial-gradient(circle, rgba(250,242,224,0.9), rgba(224,190,140,0.16) 60%, transparent 74%);"></div>
        <span aria-hidden="true" style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-family:var(--serif); font-style:italic; font-weight:500; font-size:clamp(72px,9vw,108px); letter-spacing:0.01em; color:rgba(79,106,87,0.3);">AD</span>
        <picture>
          <source srcset="/images/arzu-portrait.avif" type="image/avif" />
          <source srcset="/images/arzu-portrait.webp" type="image/webp" />
          <img class="korumali-gorsel" draggable="false" oncontextmenu="return false" src="/images/arzu-portrait.jpg" alt="Uzman Klinik Psikolog Arzu Duman portresi" width="800" height="1000" loading="lazy" decoding="async" onerror="this.remove()" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 30%; z-index:3;" />
        </picture>
      </div>
    </div>

    <div data-reveal data-reveal-delay="120" class="about-text">
      <Eyebrow label={about.eyebrow} />
      <h2 style="margin:0 0 26px; font-family:var(--serif); font-weight:500; font-size:clamp(32px,4.6vw,58px); line-height:1.04; letter-spacing:-0.015em; color:var(--ink);">{about.headingBefore}<span class="glow-accent" style="font-style:italic;">{about.headingAccent}</span></h2>

      {about.paragraphs.map((p, i) => (
        <p class={i === 0 ? 'about-lead' : ''} style="margin:0 0 20px; font-size:16.5px; line-height:1.8; color:var(--ink-soft);">{p}</p>
      ))}

      <div style="display:flex; flex-direction:column; gap:14px; margin:28px 0 32px;">
        {about.credentials.map((c) => (
          <div style="display:flex; gap:14px; align-items:flex-start;">
            <span aria-hidden="true" style="flex-shrink:0; margin-top:2px; display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:50%; background:rgba(126,154,134,0.18); color:var(--sage-deep); font-size:12px;">✓</span>
            <span style="font-size:15px; line-height:1.6; color:var(--ink-2);">{c}</span>
          </div>
        ))}
      </div>

      <div style="display:flex; flex-wrap:wrap; gap:10px;">
        {about.values.map((v) => (
          <span style="padding:9px 16px; border-radius:999px; background:var(--paper-hi); border:1px solid var(--line); font-size:13px; font-weight:600; color:var(--ink-2);">{v}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-glow {
    position: absolute; z-index: 0; top: 50%; left: 50%; transform: translate(-50%,-50%);
    width: 118%; aspect-ratio: 1; border-radius: 50%;
    background: conic-gradient(from 30deg, #8CAE95, #E0B478, #C0835A, #7BAE86, #8CAE95);
    filter: blur(46px); opacity: .34; animation: spin 22s linear infinite;
  }
  .about-lead::first-letter {
    float: left; font-family: var(--serif); font-size: 3.4em; line-height: 0.82;
    padding: 6px 12px 0 0; color: var(--sage-deep); font-weight: 500;
  }
  @media (max-width: 880px) {
    .about-grid { grid-template-columns: 1fr !important; }
    /* width:100% şart: margin:auto ile shrink-to-fit olup portre 0x0'a çökmesin. */
    .about-portrait { width: 100%; max-width: 360px; margin: 0 auto; }
  }
</style>
