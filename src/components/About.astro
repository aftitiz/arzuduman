---
import Eyebrow from './Eyebrow.astro';
const { about } = Astro.props;
---

<section id="hakkimda" style="background:#ECE5D7; padding:clamp(72px,9vw,124px) clamp(20px,6vw,88px);">
  <div style="max-width:1120px; margin:0 auto; display:flex; flex-wrap:wrap; gap:clamp(40px,6vw,80px); align-items:center;">
    <!-- Portre -->
    <div data-reveal style="flex:1 1 320px; min-width:280px; position:relative;">
      <div style="position:absolute; inset:-20px -20px 26px 20px; border-radius:230px 230px 24px 24px; border:1px solid rgba(27,38,33,0.16); z-index:0;"></div>
      <div style="position:relative; z-index:1; border-radius:220px 220px 20px 20px; overflow:hidden; aspect-ratio:4/5; background:#DBD2C0; box-shadow:0 40px 90px rgba(27,38,33,0.20);">
        <img
          src={about.portrait.src}
          alt={about.portrait.alt}
          width="480"
          height="600"
          loading="lazy"
          style="width:100%; height:100%; object-fit:cover;"
        />
      </div>
    </div>

    <!-- Metin -->
    <div data-reveal data-reveal-delay="120" style="flex:1.25 1 420px; min-width:300px;">
      <Eyebrow label={about.eyebrow} />
      <h2 style="margin:0 0 24px; font-family:var(--serif); font-weight:500; font-size:clamp(32px,4.4vw,54px); line-height:1.06; letter-spacing:-0.01em; color:#1B2621;">{about.heading}</h2>

      {about.paragraphs.map((p) => (
        <p style="margin:0 0 18px; font-size:16.5px; line-height:1.74; color:#3E463F;">{p}</p>
      ))}

      <div style="display:flex; flex-direction:column; gap:13px; margin:12px 0 30px;">
        {about.credentials.map((c) => (
          <div style="display:flex; gap:14px; align-items:flex-start;">
            <span style="flex-shrink:0; margin-top:2px; font-family:var(--serif); font-size:19px; font-style:italic; color:#C4834F;">✦</span>
            <span style="font-size:15px; line-height:1.55; color:#2E3630;">{c}</span>
          </div>
        ))}
      </div>

      <div style="display:flex; flex-wrap:wrap; gap:10px;">
        {about.values.map((v) => (
          <span style="padding:9px 16px; border-radius:999px; background:rgba(27,38,33,0.05); border:1px solid rgba(27,38,33,0.12); font-size:13px; font-weight:600; color:#2E3630;">{v}</span>
        ))}
      </div>
    </div>
  </div>
</section>
