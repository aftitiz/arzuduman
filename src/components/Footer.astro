---
const { footer, contact } = Astro.props;
---

<footer style="position:relative; overflow:hidden; background:radial-gradient(130% 110% at 50% 42%, var(--night-2) 0%, var(--night) 62%, var(--night-deep) 100%); color:#C9C1B0; padding:clamp(92px,10vw,124px) var(--pad-x) 40px;">
  <div aria-hidden="true" style="position:absolute; top:0; left:0; right:0; height:130px; background:linear-gradient(180deg, var(--night-deep) 0%, transparent 100%); z-index:0;"></div>
  <div aria-hidden="true" style="position:absolute; inset:0; background:radial-gradient(110% 85% at 50% 16%, rgba(232,196,140,0.12), transparent 58%);"></div>

  <div style="position:relative; z-index:2; max-width:1200px; margin:0 auto;">
    <div data-reveal style="display:flex; flex-direction:column; align-items:center; text-align:center; gap:clamp(30px,4vw,44px); padding-bottom:clamp(56px,7vw,84px); border-bottom:1px solid rgba(244,237,224,0.12);">
      <span style="font-family:var(--sans); font-size:12px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:#9A8E6E;">{footer.closingEyebrow}</span>
      <div style="font-family:var(--serif); font-style:italic; font-size:clamp(34px,6vw,72px); line-height:1; color:#F4EDE0; display:flex; align-items:center; gap:clamp(18px,3vw,34px); flex-wrap:wrap; justify-content:center; letter-spacing:-0.01em;">
        {footer.closingWords.map((w, i) => (
          <>
            {i > 0 && <span aria-hidden="true" style="width:7px; height:7px; border-radius:50%; background:#E0B478;"></span>}
            <span>{w}</span>
          </>
        ))}
      </div>
      <a href={footer.ctaHref} class="footer-cta" style="display:inline-flex; align-items:center; gap:10px; padding:18px 34px; border-radius:999px; background:linear-gradient(135deg,#8CAE95,#5E7A66); color:#14100B; font-size:15px; font-weight:700; box-shadow:0 18px 44px rgba(140,174,149,0.28);">{footer.ctaLabel}<span style="font-size:17px;">→</span></a>
    </div>

    <div style="display:flex; flex-wrap:wrap; gap:40px; justify-content:space-between; padding:clamp(40px,5vw,56px) 0;">
      <div style="flex:1 1 280px; min-width:240px;">
        <div style="display:inline-flex; align-items:center; gap:10px; font-family:var(--serif); font-size:25px; color:#F4EDE0; margin-bottom:14px;">
          <span aria-hidden="true" style="width:7px; height:7px; border-radius:50%; background:linear-gradient(135deg,#8CAE95,#E0B478);"></span>{footer.brandName}
        </div>
        <p style="margin:0; max-width:320px; font-size:14px; line-height:1.7; color:#8F8672; white-space:pre-line;">{footer.tagline}</p>
      </div>
      <div style="display:flex; gap:clamp(40px,6vw,72px); flex-wrap:wrap;">
        <div>
          <div class="label-soft" style="margin-bottom:18px; color:#9A8E6E;">{footer.contactHeading}</div>
          <div style="display:flex; flex-direction:column; gap:11px; font-size:14.5px;">
            <a href={`mailto:${contact.email}`} style="color:#D8D0BE;">{contact.email}</a>
            <a href={`https://instagram.com/${contact.instagram}`} target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:8px; color:#D8D0BE; width:fit-content;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              @{contact.instagram}
            </a>
            <span style="color:#8F8672;">{contact.location}</span>
          </div>
        </div>
        <div>
          <div class="label-soft" style="margin-bottom:18px; color:#9A8E6E;">{footer.hoursHeading}</div>
          <div style="display:flex; flex-direction:column; gap:11px; font-size:14.5px; color:#D8D0BE;">
            <span>{contact.hours.days}</span>
            <span>{contact.hours.time}</span>
            <span style="color:#8F8672;">{contact.hours.note}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="label-soft" style="display:flex; flex-wrap:wrap; gap:14px; justify-content:space-between; align-items:center; padding-top:26px; border-top:1px solid rgba(244,237,224,0.12); text-transform:none; letter-spacing:0.03em; color:#8F8672;">
      <span>{footer.copyright}</span>
      <div style="display:flex; gap:24px;">
        {footer.links.map((link) => (
          <a href={link.href} style="color:#B7AF9E;">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
