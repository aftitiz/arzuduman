---
import Eyebrow from './Eyebrow.astro';
const { specialties } = Astro.props;

/* Her uzmanlık alanına özel, elle çizilmiş çizgi-ikon seti.
   Sıra content.json'daki items sırasıyla eşleşir (0..6).
   Ortak stil: 32'lik viewBox, 1.5px sage çizgi, yuvarlak uçlar. */
const icons = [
  /* 0 · Kaygı & Anksiyete — huzursuz zihnin dalgalanan halkaları */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="16" r="2.2"/><path d="M11 21a7 7 0 0 1 0-10"/><path d="M21 11a7 7 0 0 1 0 10"/><path d="M8 24a11.5 11.5 0 0 1 0-16" opacity=".45"/><path d="M24 8a11.5 11.5 0 0 1 0 16" opacity=".45"/></svg>`,
  /* 1 · İlişki & Çift — iç içe geçen iki alan */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12.5" cy="16" r="7.2"/><circle cx="19.5" cy="16" r="7.2"/></svg>`,
  /* 2 · İş Stresi & Tükenmişlik — tükenen kum saati */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6h14"/><path d="M9 26h14"/><path d="M10 6 16 16 10 26"/><path d="M22 6 16 16 22 26"/><path d="M13 24h6" opacity=".55"/></svg>`,
  /* 3 · Özgüven & Gelişim — filizlenen fidan */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 27v-9"/><path d="M16 18c-4 0-7-2-8-6 4 0 7 2 8 6Z"/><path d="M16 20c4 0 7-2 8-6-4 0-7 2-8 6Z"/></svg>`,
  /* 4 · Panik Atak & Fobiler — hızlanan kalp atışı */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 16h6l2-7 3.5 13 2.5-9 1.5 3h8.5"/></svg>`,
  /* 5 · Öfke & Duygu Düzenleme — sönümlenerek sakinleşen dalga */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16q3-8 6 0 3 6 6 0 3-4 6 0 2.5 2.5 5 0"/></svg>`,
  /* 6 · Travma & Kayıp / Yas — koruyan kavis altında bir kalp */
  `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 14a10 10 0 0 1 20 0" opacity=".55"/><path d="M16 27c-4-3.2-7-5.4-7-8.6a3.5 3.5 0 0 1 7-1 3.5 3.5 0 0 1 7 1c0 3.2-3 5.4-7 8.6Z"/></svg>`,
];

/* Kapanış kartındaki sohbet baloncuğu */
const chatIcon = `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h18a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H14l-5 4v-4H7a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Z"/><path d="M11 12.5h10M11 16.5h6"/></svg>`;
---

<section id="uzmanlik" class="section-full" style="position:relative; overflow:hidden; background:linear-gradient(180deg,var(--tone-3),var(--tone-4)); padding:clamp(52px,6vw,88px) var(--pad-x);">
  <div aria-hidden="true" class="aur" style="bottom:-12%; left:-8%; width:min(46vw,520px); height:min(46vw,520px); background:radial-gradient(circle,rgba(224,180,120,0.22),transparent 66%); animation:drift2 28s ease-in-out infinite;"></div>

  <div style="position:relative; z-index:2; width:100%; max-width:1240px; margin:0 auto;">
    <div data-reveal class="spec-head">
      <Eyebrow label={specialties.eyebrow} />
      <h2 style="margin:0 0 18px; font-family:var(--serif); font-weight:500; font-size:clamp(32px,4.6vw,60px); line-height:1.02; letter-spacing:-0.015em; color:var(--ink);">{specialties.heading}</h2>
      <p style="margin:0; font-size:16.5px; line-height:1.74; color:var(--ink-soft);">{specialties.intro}</p>
    </div>

    <div class="spec-grid">
      {specialties.items.map((s, i) => (
        <article class="spec-card card-lift" data-reveal data-reveal-delay={(i % 4) * 70}>
          <span class="spec-ico" aria-hidden="true" set:html={icons[i % icons.length]} />
          <h3 class="spec-title">{s.title}</h3>
          <p class="spec-desc">{s.desc}</p>
        </article>
      ))}

      {specialties.closing && (
        <a class="spec-card spec-cta card-lift" href={specialties.closing.href} data-reveal data-reveal-delay={(specialties.items.length % 4) * 70}>
          <span class="spec-ico" aria-hidden="true" set:html={chatIcon} />
          <div class="spec-cta-body">
            <h3 class="spec-title">{specialties.closing.title}</h3>
            <p class="spec-desc">{specialties.closing.desc}</p>
          </div>
          <span class="spec-cta-link">
            {specialties.closing.cta}
            <span class="spec-cta-arrow" aria-hidden="true">→</span>
          </span>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .spec-head { max-width: 660px; }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 248px), 1fr));
    gap: clamp(14px, 1.5vw, 20px);
    margin-top: clamp(34px, 4.4vw, 56px);
  }

  .spec-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: clamp(22px, 2.4vw, 30px);
    background: var(--paper-hi);
    border: 1px solid var(--line);
    border-radius: 20px;
    box-shadow: 0 4px 16px rgba(38, 48, 42, 0.04);
    text-decoration: none;
  }

  .spec-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 15px;
    margin-bottom: 20px;
    background: rgba(110, 139, 118, 0.1);
    color: var(--sage-deep);
    transition: background .4s ease, color .4s ease, transform .4s var(--ease);
  }
  .spec-ico :global(svg) { width: 27px; height: 27px; }

  .spec-card:hover .spec-ico {
    background: rgba(224, 180, 120, 0.2);
    color: var(--clay);
    transform: scale(1.06);
  }

  .spec-title {
    margin: 0 0 8px;
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 24px);
    line-height: 1.14;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .spec-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* ---- Kapanış / sohbet-davet kartı (tek aksan) ---- */
  .spec-cta {
    justify-content: space-between;
    background: linear-gradient(158deg, rgba(110, 139, 118, 0.16), rgba(110, 139, 118, 0.07));
    border-color: rgba(110, 139, 118, 0.3);
  }
  .spec-cta .spec-ico {
    background: rgba(110, 139, 118, 0.2);
    color: var(--sage-deep);
  }
  .spec-cta:hover .spec-ico {
    background: rgba(110, 139, 118, 0.3);
    color: var(--sage-deep);
    transform: scale(1.06);
  }
  .spec-cta-body { flex: 1; }
  .spec-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 18px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--sage-deep);
  }
  .spec-cta-arrow { transition: transform .3s var(--ease); }
  .spec-cta:hover .spec-cta-arrow { transform: translateX(5px); }

  @media (max-width: 560px) {
    .spec-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .spec-card { border-radius: 16px; padding: 18px 16px 20px; }
    .spec-ico {
      width: 46px; height: 46px; border-radius: 13px; margin-bottom: 14px;
    }
    .spec-ico :global(svg) { width: 23px; height: 23px; }
    .spec-title { font-size: 18px; margin-bottom: 6px; }
    .spec-desc { font-size: 13px; line-height: 1.5; }
    .spec-cta-link { margin-top: 14px; font-size: 12.5px; }
  }
  @media (max-width: 360px) {
    .spec-grid { gap: 10px; }
    .spec-card { padding: 16px 13px 18px; }
  }
</style>
