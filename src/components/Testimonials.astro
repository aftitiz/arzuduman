---
import Eyebrow from './Eyebrow.astro';
const { testimonials } = Astro.props;
---

<section id="deneyimler" style="position:relative; overflow:hidden; background:var(--paper-2); padding:clamp(84px,11vw,150px) var(--pad-x);">
  <div aria-hidden="true" class="aur" style="top:-6%; left:40%; width:min(46vw,520px); height:min(46vw,520px); background:radial-gradient(circle,rgba(224,180,120,0.2),transparent 66%);"></div>

  <div style="position:relative; z-index:2; max-width:1200px; margin:0 auto;">
    <div data-reveal style="max-width:700px; margin-bottom:clamp(48px,6vw,72px);">
      <Eyebrow label={testimonials.eyebrow} />
      <h2 style="margin:0; font-family:var(--serif); font-weight:500; font-size:clamp(32px,4.6vw,60px); line-height:1.02; letter-spacing:-0.015em; color:var(--ink);">{testimonials.heading}</h2>
    </div>

    <div class="tst-grid">
      {testimonials.items.map((t, i) => (
        <figure data-reveal data-reveal-delay={i * 100} class="tst-card card-lift" style="margin:0; display:flex; flex-direction:column; padding:32px 30px; border-radius:22px; background:var(--paper-hi); border:1px solid var(--line);">
          <span aria-hidden="true" class="tst-mark">”</span>
          <blockquote style="margin:0 0 24px; font-family:var(--serif); font-weight:500; font-size:clamp(20px,1.9vw,24px); line-height:1.44; letter-spacing:-0.005em; color:var(--ink-2);">{t.quote}</blockquote>
          <figcaption style="margin-top:auto; display:flex; align-items:center; gap:13px; padding-top:20px; border-top:1px solid var(--line);">
            <span style="display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%; background:rgba(126,154,134,0.16); border:1px solid rgba(126,154,134,0.28); font-family:var(--serif); font-size:15px; color:var(--sage-deep);">{t.initials}</span>
            <span class="label-soft" style="text-transform:none; letter-spacing:0.02em; color:var(--ink-soft);">{t.meta}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p data-reveal class="label-soft" style="max-width:680px; margin:clamp(36px,5vw,52px) 0 0; line-height:1.7; text-transform:none; letter-spacing:0.01em; color:var(--ink-dim);">{testimonials.note}</p>
  </div>
</section>

<style>
  .tst-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 2.4vw, 30px); }
  .tst-card:nth-child(2) { transform: translateY(clamp(18px, 3vw, 40px)); }
  .tst-card:nth-child(2):hover { transform: translateY(calc(clamp(18px,3vw,40px) - 6px)); }
  .tst-mark { display: block; font-family: var(--serif); font-size: 64px; line-height: 0.1; height: 30px; color: var(--sage-soft); opacity: 0.7; }
  @media (max-width: 820px) {
    .tst-grid { grid-template-columns: 1fr; gap: 18px; }
    .tst-card:nth-child(2) { transform: none; }
    .tst-card:nth-child(2):hover { transform: translateY(-6px); }
  }
</style>
