---
import Eyebrow from './Eyebrow.astro';
const { testimonials } = Astro.props;
---

<section
  id="deneyimler"
  data-index-section
  data-label="Deneyimler"
  style="position:relative; overflow:hidden; background:var(--ink); padding:clamp(84px,11vw,150px) var(--pad-x);"
>
  <div style="max-width:1200px; margin:0 auto;">
    <div data-reveal style="max-width:700px; margin-bottom:clamp(48px,6vw,72px);">
      <Eyebrow label={testimonials.eyebrow} />
      <h2 style="margin:0; font-family:var(--serif); font-weight:500; font-size:clamp(32px,4.6vw,60px); line-height:1.02; letter-spacing:-0.015em; color:var(--bone);">{testimonials.heading}</h2>
    </div>

    <div class="tst-grid">
      {testimonials.items.map((t, i) => (
        <figure data-reveal data-reveal-delay={i * 100} class="tst-col">
          <span aria-hidden="true" class="tst-mark">”</span>
          <blockquote style="margin:0 0 26px; font-family:var(--serif); font-weight:500; font-size:clamp(21px,2vw,26px); line-height:1.42; letter-spacing:-0.005em; color:var(--bone-2);">{t.quote}</blockquote>
          <figcaption style="display:flex; align-items:center; gap:13px; padding-top:20px; border-top:1px solid var(--line);">
            <span style="display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%; background:rgba(201,161,107,0.12); border:1px solid rgba(201,161,107,0.22); font-family:var(--serif); font-size:15px; color:var(--gold);">{t.initials}</span>
            <span class="label-mono" style="color:var(--mist);">{t.meta}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p data-reveal class="label-mono" style="max-width:680px; margin:clamp(40px,5vw,56px) 0 0; line-height:1.7; text-transform:none; letter-spacing:0.02em; color:var(--mist-dim);">{testimonials.note}</p>
  </div>
</section>

<style>
  .tst-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(28px, 4vw, 56px);
  }
  .tst-col { margin: 0; display: flex; flex-direction: column; }
  .tst-col:nth-child(2) { transform: translateY(clamp(20px, 4vw, 52px)); }
  .tst-mark {
    display: block; font-family: var(--serif); font-size: 72px; line-height: 0.1;
    height: 34px; color: var(--gold); opacity: 0.55;
  }
  @media (max-width: 820px) {
    .tst-grid { grid-template-columns: 1fr; gap: 40px; }
    .tst-col:nth-child(2) { transform: none; }
  }
</style>
