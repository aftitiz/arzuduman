---
// Fontlar kendi sunucumuzdan (self-hosted) yüklenir: dış Google Fonts isteği yok
// → FOUT/flash yok, layout kayması yok, KVKK/gizlilik açısından üçüncü taraf isteği yok.
import '@fontsource-variable/cormorant-garamond/index.css';
import '@fontsource-variable/cormorant-garamond/wght-italic.css';
import '@fontsource-variable/manrope/index.css';
import '../styles/global.css';

import cormorantLatin from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-normal.woff2?url';
import cormorantItalicLatin from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-italic.woff2?url';
import manropeLatin from '@fontsource-variable/manrope/files/manrope-latin-wght-normal.woff2?url';

const { site, faqs = [], title, description, noindex = false } = Astro.props;

const pageTitle = title ?? site.title;
const pageDescription = description ?? site.description;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImageUrl = new URL(site.ogImage, Astro.site ?? site.url).href;

const robotsContent = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const seo = site.seo ?? {};
const contact = site.contact ?? {};
// Yer tutucu (0000…) telefonu yapısal veriye koyma; yalnızca gerçek numara ekle.
const realPhone = contact.phoneHref && !/0{6,}/.test(contact.phoneHref) ? contact.phoneHref : null;
const instagramUrl = contact.instagram ? `https://www.instagram.com/${contact.instagram}` : null;
const sameAs = [instagramUrl, ...(seo.sameAs ?? [])].filter(Boolean);
const areaList = Array.isArray(seo.areaServed) ? seo.areaServed : seo.areaServed ? [seo.areaServed] : [];

const postalAddress = {
  '@type': 'PostalAddress',
  ...(seo.streetAddress ? { streetAddress: seo.streetAddress } : {}),
  addressLocality: contact.addressLocality,
  ...(seo.addressRegion ? { addressRegion: seo.addressRegion } : {}),
  ...(seo.postalCode ? { postalCode: seo.postalCode } : {}),
  addressCountry: contact.addressCountry,
};

const person = site.person ?? {};
const personImageUrl = person.image ? new URL(person.image, Astro.site ?? site.url).href : ogImageUrl;
const practiceId = `${site.url}/#practice`;
const personId = `${site.url}/#person`;
const websiteId = `${site.url}/#website`;

const websiteLd = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: site.url,
  name: site.name,
  inLanguage: 'tr-TR',
  publisher: { '@id': practiceId },
};

const psychologistLd = {
  '@type': ['Psychologist', 'LocalBusiness'],
  '@id': practiceId,
  name: site.name,
  alternateName: `${person.jobTitle ?? 'Klinik Psikolog'} ${site.name}`,
  description: site.description,
  url: site.url,
  email: contact.email,
  ...(realPhone ? { telephone: realPhone } : {}),
  image: ogImageUrl,
  logo: ogImageUrl,
  priceRange: seo.priceRange,
  ...(seo.currency ? { currenciesAccepted: seo.currency } : {}),
  address: postalAddress,
  ...(seo.geo
    ? { geo: { '@type': 'GeoCoordinates', latitude: seo.geo.latitude, longitude: seo.geo.longitude } }
    : {}),
  areaServed: areaList.map((a) => ({
    // Ülke düzeyi (online = tüm Türkiye) Country; şehir/bölge AdministrativeArea.
    '@type': /türkiye|turkey/i.test(a) ? 'Country' : 'AdministrativeArea',
    name: a,
  })),
  availableLanguage: { '@type': 'Language', name: 'Turkish' },
  ...(person.knowsAbout?.length ? { knowsAbout: person.knowsAbout } : {}),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
  ],
  founder: { '@id': personId },
  employee: { '@id': personId },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Psikoterapi Hizmetleri',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Online Terapi',
          serviceType: 'Psikoterapi',
          areaServed: { '@type': 'Country', name: 'Türkiye' },
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Yüz Yüze Terapi',
          serviceType: 'Psikoterapi',
          areaServed: { '@type': 'City', name: seo.inPersonArea ?? 'Samsun' },
        },
      },
      {
        '@type': 'Offer',
        price: '0',
        priceCurrency: seo.currency ?? 'TRY',
        itemOffered: {
          '@type': 'Service',
          name: 'Ücretsiz Ön Görüşme',
          serviceType: 'Ön görüşme',
        },
      },
    ],
  },
  ...(sameAs.length ? { sameAs } : {}),
};

const personLd = {
  '@type': 'Person',
  '@id': personId,
  name: person.name ?? site.name,
  jobTitle: person.jobTitle ?? 'Klinik Psikolog',
  description: person.description ?? site.description,
  url: site.url,
  image: personImageUrl,
  worksFor: { '@id': practiceId },
  knowsLanguage: { '@type': 'Language', name: 'Turkish' },
  ...(person.knowsAbout?.length ? { knowsAbout: person.knowsAbout } : {}),
  ...(person.credentials?.length
    ? {
        hasCredential: person.credentials.map((c) => ({
          '@type': 'EducationalOccupationalCredential',
          name: c,
        })),
      }
    : {}),
  ...(sameAs.length ? { sameAs } : {}),
};

const faqLd = {
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const jsonLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [websiteLd, psychologistLd, personLd, ...(faqs.length > 0 ? [faqLd] : [])],
};

const geoPosition = seo.geo ? `${seo.geo.latitude};${seo.geo.longitude}` : null;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content={site.themeColor} />
    <meta name="author" content={site.person?.name ?? site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="alternate" hreflang="tr" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <meta name="geo.region" content="TR-55" />
    <meta name="geo.placename" content={site.contact?.addressLocality} />
    {geoPosition && <meta name="geo.position" content={geoPosition} />}
    {geoPosition && <meta name="ICBM" content={geoPosition.replace(';', ', ')} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.person?.jobTitle ?? 'Klinik Psikolog'}`} />
    <meta property="og:locale" content={site.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${site.name} — ${site.person?.jobTitle ?? 'Klinik Psikolog'}`} />

    <link rel="preload" href={cormorantLatin} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={cormorantItalicLatin} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={manropeLatin} as="font" type="font/woff2" crossorigin="anonymous" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <div
      data-progress
      style="position:fixed; top:0; left:0; height:2px; width:0%; background:linear-gradient(90deg,var(--sage-deep),var(--amber)); z-index:101; transition:width .12s linear;"
    >
    </div>
    <slot />
  </body>
</html>
