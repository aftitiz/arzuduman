---
import content from '../data/content.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Reveal from '../components/Reveal.astro';
---

<BaseLayout
  site={content.site}
  title={`Sayfa bulunamadı — ${content.site.name}`}
  description="Aradığınız sayfa bulunamadı. Ana sayfaya dönebilir ya da ücretsiz ön görüşme planlayabilirsiniz."
  noindex={true}
>
  <Nav nav={content.nav} />

  <main style="background:var(--paper); min-height:100vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:clamp(120px,16vh,180px) var(--pad-x) clamp(60px,8vw,100px);">
    <div style="max-width:560px; margin:0 auto;">
      <p class="label-soft" style="margin:0 0 18px; color:var(--sage-deep);">404</p>
      <h1 style="margin:0 0 18px; font-family:var(--serif); font-weight:500; font-size:clamp(34px,6vw,60px); line-height:1.05; letter-spacing:-0.015em; color:var(--ink);">Bu sayfa bulunamadı.</h1>
      <p style="margin:0 0 34px; font-size:17px; line-height:1.75; color:var(--ink-soft);">Aradığınız sayfa taşınmış ya da hiç var olmamış olabilir. Buradan sakince devam edebilirsiniz.</p>
      <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
        <a href="/" class="btn-accent" style="display:inline-flex; align-items:center; gap:10px; padding:16px 28px; border-radius:999px; font-size:15px; font-weight:700;">Ana sayfaya dön<span aria-hidden="true">→</span></a>
        <a href="/#randevu" class="btn-glass" style="display:inline-flex; align-items:center; gap:8px; padding:15px 24px; border-radius:999px; font-size:15px; font-weight:600;">Ön görüşme planla</a>
      </div>
    </div>
  </main>

  <Footer footer={content.footer} contact={content.site.contact} />
  <Reveal />
</BaseLayout>
